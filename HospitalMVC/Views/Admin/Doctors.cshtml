



                    @using HospitalMVC.Models

@model List<Doctor>

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid py-4">

    <!-- PAGE TITLE -->
    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>
            <h2 class="fw-bold mb-1">
                Doctor Management
            </h2>

            <p class="text-muted mb-0">
                Add, edit and manage doctors
            </p>
        </div>

    </div>

    <!-- SUCCESS MESSAGE -->
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">

            @TempData["Success"]

            <button type="button"
                    class="btn-close"
                    data-bs-dismiss="alert"></button>

        </div>
    }

    <!-- ERROR MESSAGE -->
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">

            @TempData["Error"]

            <button type="button"
                    class="btn-close"
                    data-bs-dismiss="alert"></button>

        </div>
    }

    <!-- ADD DOCTOR CARD -->
    <div class="card border-0 shadow-sm mb-5"
         style="border-radius:20px;">

        <div class="card-body p-4">

            <h4 class="fw-bold mb-4">
                Add New Doctor
            </h4>

            <form asp-action="AddDoctor"
                  method="post">

                <div class="row">

                    <!-- NAME -->
                    <div class="col-md-6 mb-4">

                        <label class="form-label fw-semibold">
                            Doctor Name
                        </label>

                        <input type="text"
                               name="Name"
                               class="form-control custom-input"
                               placeholder="Enter doctor name"
                               required />

                    </div>

                    <!-- SPECIALIZATION -->
                    <div class="col-md-6 mb-4">

                        <label class="form-label fw-semibold">
                            Specialization
                        </label>

                        <input type="text"
                               name="Specialization"
                               class="form-control custom-input"
                               placeholder="Enter specialization"
                               required />

                    </div>

                    <!-- DESCRIPTION -->
                    <div class="col-md-12 mb-4">

                        <label class="form-label fw-semibold">
                            Description
                        </label>

                        <textarea name="Description"
                                  rows="5"
                                  class="form-control custom-input"
                                  placeholder="Enter doctor description"
                                  required></textarea>

                    </div>

                    <!-- IMAGE URL -->
                    <div class="col-md-12 mb-4">

                        <label class="form-label fw-semibold">
                            Doctor Image URL
                        </label>

                        <input type="text"
                               name="ImageUrl"
                               class="form-control custom-input"
                               placeholder="Paste image URL"
                               required />

                    </div>

                    <!-- BUTTON -->
                    <div class="col-md-12">

                        <button type="submit"
                                class="btn add-btn">

                            Add Doctor

                        </button>

                    </div>

                </div>

            </form>

        </div>

    </div>

    <!-- DOCTOR TABLE -->
    <div class="card border-0 shadow-sm"
         style="border-radius:20px;">

        <div class="card-body p-4">

            <h4 class="fw-bold mb-4">
                Doctors List
            </h4>

            <div class="table-responsive">

                <table class="table align-middle">

                    <thead class="table-light">

                        <tr>

                            <th>Image</th>

                            <th>Name</th>

                            <th>Specialization</th>

                            <th>Description</th>

                            <th class="text-center">
                                Actions
                            </th>

                        </tr>

                    </thead>

                    <tbody>

                        @if (Model != null && Model.Any())
                        {
                            @foreach (var d in Model)
                            {
                                <tr>

                                    <!-- IMAGE -->
                                    <td>

                                        <img src="@d.ImageUrl"
                                             class="doctor-img" />

                                    </td>

                                    <!-- NAME -->
                                    <td class="fw-semibold">
                                        @d.Name
                                    </td>

                                    <!-- SPECIALIZATION -->
                                    <td>
                                        @d.Specialization
                                    </td>

                                    <!-- DESCRIPTION -->
                                    <td style="max-width:300px;">
                                        @d.Description
                                    </td>

                                    <!-- ACTIONS -->
                                    <td class="text-center">

                                        <!-- EDIT -->
                                        <button class="btn btn-warning btn-sm editBtn"
                                                data-id="@d.Id"
                                                data-name="@d.Name"
                                                data-spec="@d.Specialization"
                                                data-description="@d.Description"
                                                data-image="@d.ImageUrl">

                                            Edit

                                        </button>

                                        <!-- DELETE -->
                                        <form asp-action="DeleteDoctor"
                                              method="post"
                                              style="display:inline;"
                                              onsubmit="return confirm('Delete this doctor?');">

                                            <input type="hidden"
                                                   name="id"
                                                   value="@d.Id" />

                                            <button type="submit"
                                                    class="btn btn-danger btn-sm">

                                                Delete

                                            </button>

                                        </form>

                                    </td>

                                </tr>
                            }
                        }
                        else
                        {
                            <tr>

                                <td colspan="5"
                                    class="text-center text-muted py-4">

                                    No doctors added yet

                                </td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>

        </div>

    </div>

</div>

<!-- EDIT MODAL -->
<div class="modal fade"
     id="editModal"
     tabindex="-1">

    <div class="modal-dialog modal-lg">

        <div class="modal-content">

            <div class="modal-header">

                <h5 class="modal-title">
                    Edit Doctor
                </h5>

                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="modal"></button>

            </div>

            <form asp-action="EditDoctor"
                  method="post">

                <div class="modal-body">

                    <!-- ID -->
                    <input type="hidden"
                           id="editId"
                           name="Id" />

                    <div class="row">

                        <!-- NAME -->
                        <div class="col-md-6 mb-4">

                            <label class="form-label">
                                Doctor Name
                            </label>

                            <input type="text"
                                   id="editName"
                                   name="Name"
                                   class="form-control custom-input"
                                   required />

                        </div>

                        <!-- SPECIALIZATION -->
                        <div class="col-md-6 mb-4">

                            <label class="form-label">
                                Specialization
                            </label>

                            <input type="text"
                                   id="editSpec"
                                   name="Specialization"
                                   class="form-control custom-input"
                                   required />

                        </div>

                        <!-- DESCRIPTION -->
                        <div class="col-md-12 mb-4">

                            <label class="form-label">
                                Description
                            </label>

                            <textarea id="editDescription"
                                      name="Description"
                                      rows="5"
                                      class="form-control custom-input"
                                      required></textarea>

                        </div>

                        <!-- IMAGE -->
                        <div class="col-md-12 mb-4">

                            <label class="form-label">
                                Image URL
                            </label>

                            <input type="text"
                                   id="editImage"
                                   name="ImageUrl"
                                   class="form-control custom-input"
                                   required />

                        </div>

                    </div>

                </div>

                <div class="modal-footer">

                    <button type="submit"
                            class="btn btn-primary">

                        Update Doctor

                    </button>

                    <button type="button"
                            class="btn btn-secondary"
                            data-bs-dismiss="modal">

                        Cancel

                    </button>

                </div>

            </form>

        </div>

    </div>

</div>

<style>

    body {
        background: #f5f7fb;
    }

    .custom-input {
        border-radius: 12px;
        padding: 12px;
        border: 1px solid #dcdcdc;
    }

    .custom-input:focus {
        border-color: #0ea5c6;
        box-shadow: none;
    }

    .add-btn {
        background: #0ea5c6;
        color: white;
        border: none;
        padding: 12px 28px;
        border-radius: 30px;
        font-weight: 600;
        transition: 0.3s ease;
    }

    .add-btn:hover {
        background: #0b8aa5;
        color: white;
    }

    .doctor-img {
        width: 70px;
        height: 70px;
        object-fit: cover;
        border-radius: 50%;
        border: 3px solid #0ea5c6;
    }

    .table td,
    .table th {
        vertical-align: middle;
    }

</style>

<script>

    document.addEventListener("DOMContentLoaded", function () {

        const editButtons =
            document.querySelectorAll(".editBtn");

        editButtons.forEach(btn => {

            btn.addEventListener("click", function () {

                document.getElementById("editId").value =
                    this.dataset.id;

                document.getElementById("editName").value =
                    this.dataset.name;

                document.getElementById("editSpec").value =
                    this.dataset.spec;

                document.getElementById("editDescription").value =
                    this.dataset.description;

                document.getElementById("editImage").value =
                    this.dataset.image;

                var modal =
                    new bootstrap.Modal(
                        document.getElementById("editModal")
                    );

                modal.show();

            });

        });

    });

</script>