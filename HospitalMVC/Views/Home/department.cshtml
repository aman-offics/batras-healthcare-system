        margin-top: 15px;
        margin-bottom: 20px;
    }

        .department-content ul li {
            margin-bottom: 8px;
        }

    .icon i {
        font-size: 32px;
        color: #0ea5c6;
    }

    .custom-btn {
        background: #0ea5c6;
        color: white;
        border-radius: 30px;
        padding: 10px 24px;
        font-weight: 600;
        border: none;
