                         </div> 
                     </div><!-- End Step --> 

                 </div> 
             </div><!-- End Process Steps --> 

         </div> 
     </div> 

 </section><!-- /Appointmnet Section -->


<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

@if (TempData["Success"] != null)
{
    <script>
        Swal.fire({
            icon: 'success',
            title: 'Success!',
            text: '@TempData["Success"]',
            confirmButtonColor: '#3085d6'
        });
    </script>
}

@if (TempData["Error"] != null)
{
    <script>
        Swal.fire({
            icon: 'error',
            title: 'Error!',
            text: '@TempData["Error"]',
            confirmButtonColor: '#d33'
        });
    </script>
}
<script>
    async function loadSlots() {
        var doctor = document.getElementById("doctor").value;
        var date = document.getElementById("date").value;

        if (!doctor || !date) return;

        let res = await fetch(`http://localhost:5113/api/appointment/slots?doctor=${doctor}&date=${date}`);
        let booked = await res.json();

        document.querySelectorAll(".slot").forEach(btn => {
            if (booked.includes(btn.value)) {
                btn.disabled = true;
                btn.classList.remove("btn-outline-primary");
                btn.classList.add("btn-secondary");
            } else {
                btn.disabled = false;
            }
        });
    }
</script>


<script>
    document.querySelectorAll(".slot").forEach(btn => {
        btn.addEventListener("click", function () {

            // remove active from all
            document.querySelectorAll(".slot").forEach(b => {
                b.classList.remove("btn-primary");
                b.classList.add("btn-outline-primary");
            });

            // activate selected
            this.classList.remove("btn-outline-primary");
            this.classList.add("btn-primary");

            // set hidden value
            document.getElementById("time").value = this.value;
        });
    });
</script>