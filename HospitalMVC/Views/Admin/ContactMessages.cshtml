@model List<ContactMessage>

<div class="container mt-5">
    <h3 class="mb-4">Contact Messages 📩</h3>

    <div class="card shadow p-4">
        <table class="table table-bordered text-center align-middle">

            <thead class="table-dark">
                <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Subject</th>
                    <th>Message</th>
                    <th>Date</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var m in Model)
                {
                    <tr>
                        <td>@m.Name</td>
                        <td>@m.Email</td>
                        <td>@m.Subject</td>
                        <td>@m.Message</td>
                        <td>@m.CreatedAt.ToString("dd-MM-yyyy")</td>
                    </tr>
                }
            </tbody>

        </table>
    </div>
</div>