<!-- DEPARTMENTS SECTION -->
@* <div class="container" > *@
    <section id="departments" class="departments section py-5" style="margin-top:100px; min-height:70vh;">

    <div class="container">

        <!-- SECTION TITLE -->
        <div class="text-center mb-5" data-aos="fade-up">
            <h2 class="fw-bold">Departments</h2>

            <p class="text-muted">
                Explore our specialized departments with advanced treatments and expert medical care.
            </p>
        </div>

        <div class="row gy-4">

            <!-- CARDIOLOGY -->
            <div class="col-lg-4 col-md-6" data-aos="fade-up">

                <div class="department-card shadow-sm h-100">

                    <div class="department-image">
                        <img src="https://images.pexels.com/photos/40568/medical-appointment-doctor-healthcare-40568.jpeg"
                             class="img-fluid"
                             alt="">
                    </div>

                    <div class="department-content p-4">

                        <div class="icon mb-3">
                            <i class="bi bi-heart-pulse-fill"></i>
                        </div>

                        <h4>Cardiology</h4>

                        <p>
                            Advanced heart care with modern diagnostic technology
                            and expert cardiac specialists.
                        </p>

                        <ul>
                            <li>ECG & Heart Scan</li>
                            <li>Cardiac Surgery</li>
                            <li>Heart Monitoring</li>
                        </ul>

                        <a asp-controller="Home"
                           asp-action="Cardiology"
                           class="btn custom-btn mt-2">
                            Learn More
                        </a>

                    </div>

                </div>

            </div>

            <!-- NEUROLOGY -->
            <div class="col-lg-4 col-md-6" data-aos="fade-up" data-aos-delay="100">

