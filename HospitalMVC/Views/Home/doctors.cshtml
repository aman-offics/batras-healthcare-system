@using HospitalMVC.Models

@model List<Doctor>

<!-- Page Title -->
<div class="page-title">

    <div class="breadcrumbs">

        <nav aria-label="breadcrumb">

            <ol class="breadcrumb">

                <li class="breadcrumb-item">
                    <a href="#">
                        <i class="bi bi-house"></i> Home
                    </a>
                </li>

                <li class="breadcrumb-item">
                    <a href="#">Category</a>
                </li>

                <li class="breadcrumb-item active current">
                    Doctors
                </li>

            </ol>

        </nav>

    </div>

</div>
<!-- End Page Title -->
<!-- DOCTORS SECTION -->
<section id="doctors"
         class="doctors section py-5">

    <div class="container">

        <!-- SECTION TITLE -->
        <div class="text-center mb-5"
             data-aos="fade-up">

            <h2 class="fw-bold">
                Our Doctors
            </h2>

            <p class="text-muted">
                Meet our experienced medical specialists dedicated to providing quality healthcare services.
            </p>

        </div>

        <div class="row gy-4">

            @if (Model != null && Model.Any())
            {
                int delay = 0;

                @foreach (var d in Model)
                {
                    <div class="col-lg-4 col-md-6"
                         data-aos="fade-up"
                         data-aos-delay="@delay">

                        <div class="doctor-card shadow-sm h-100">

                            <!-- IMAGE -->
                            <img src="@d.ImageUrl"
                                 class="img-fluid doctor-img"
                                 alt="Doctor">

                            <!-- CONTENT -->
                            <div class="p-4 text-center">

                                <h4 class="fw-bold mb-1">
                                    @d.Name
                                </h4>

                                <span class="doctor-speciality">
                                    @d.Specialization
                                </span>

                                <p class="mt-3 text-muted">
                                    @d.Description
                                </p>

                                <a asp-controller="Home"
                                   asp-action="Appointment"
                                   class="btn custom-btn mt-2">

                                    Book Appointment

                                </a>

                            </div>

                        </div>

                    </div>

                    delay += 100;
                }
            }
            else
            {
                <div class="col-12 text-center">

                    <h4 class="text-muted">
                        No doctors available
                    </h4>

                </div>
            }

        </div>

    </div>

</section>

<style>

    .doctor-card {
        background: #fff;
        border-radius: 18px;
        overflow: hidden;
        transition: 0.3s ease;
    }

        .doctor-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 15px 30px rgba(0,0,0,0.12);
        }

    .doctor-img {
        width: 100%;
        height: 320px;
        object-fit: cover;
    }

    .doctor-speciality {
        color: #0ea5c6;
        font-weight: 600;
        font-size: 15px;
    }

    .custom-btn {
        background: #0ea5c6;
        color: white;
        border: none;
        border-radius: 30px;
        padding: 10px 24px;
        font-weight: 600;
        transition: 0.3s ease;
    }

        .custom-btn:hover {
            background: #0b8aa5;
            color: white;
        }

</style>