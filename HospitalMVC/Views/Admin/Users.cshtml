@model List<HospitalMVC.Models.User>

@{
    ViewData["Title"] = "Users";
}

<div class="container mt-4">

    <h2 class="mb-4">Users 👥</h2>

    <table class="table table-bordered table-striped shadow">
        <thead class="table-dark">
            <tr>
                <th>Id</th>
                <th>Name</th>
                <th>Email</th>
                <th>Role</th>
                <th>Status</th>
                <th>Action</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var user in Model)
            {
                <tr>
                    <td>@user.Id</td>
                    <td>@user.Name</td>
                    <td>@user.Email</td>
                    <td>@user.Role</td>

                    <!-- STATUS -->
                    <td>
                        @if (user.IsActive)
                        {
                            <span class="badge bg-success">Active ✅</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">Inactive ❌</span>
                        }
                    </td>

                    <!-- ACTION -->
                    <td>
                        @if (user.Role == "Admin")
                        {
                            <span class="badge bg-secondary">Protected 🔒</span>
                        }
                        else
                        {
                            <a asp-action="ToggleStatus" asp-route-id="@user.Id"
                               class="btn @(user.IsActive ? "btn-danger" : "btn-success") btn-sm">

                                @(user.IsActive ? "Deactivate" : "Activate")
                            </a>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>

</div>